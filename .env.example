# Brain Agent Platform — local dev environment
# Copy to .env and adjust as needed.

# App
APP_ENV=dev
APP_NAME=juno-brain
LOG_LEVEL=INFO
LOG_FORMAT=json

# API
API_HOST=0.0.0.0
API_PORT=8000

# Database
DATABASE_URL=postgresql+psycopg://juno:juno@localhost:5432/juno_brain

# Dev auth placeholder — every request is attributed to this user until real auth lands.
DEV_USER_ID=user_dev
DEV_USER_EMAIL=dev@local

# LLM (unused in stage 1; here so later stages can pick them up)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
